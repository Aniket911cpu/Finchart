generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS ───────────────────────────────────────────────────────

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  username      String?       @unique
  passwordHash  String?
  plan          Plan          @default(FREE)
  bio           String?
  timezone      String?       @default("UTC")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  accounts      Account[]
  sessions      Session[]
  watchlists    Watchlist[]
  alerts        Alert[]
  layouts       Layout[]
  drawings      Drawing[]
  indicators    SavedIndicator[]
  notifications Notification[]
  settings      UserSettings?
  apiKeys       ApiKey[]
  alertHistory  AlertHistory[]
  // Social
  ideas         Idea[]
  ideaComments  IdeaComment[]
  ideaLikes     IdeaLike[]
  followers     Follow[]      @relation("followers")
  following     Follow[]      @relation("following")
  // Paper Trading
  paperAccount  PaperAccount?
  // Screener
  savedScreeners SavedScreener[]
  // Scripts
  scripts       Script[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

// ─── SESSIONS ────────────────────────────────────────────────────

model Session {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  deviceInfo  String?
  ipAddress   String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── WATCHLISTS ──────────────────────────────────────────────────

model Watchlist {
  id        String          @id @default(cuid())
  userId    String
  name      String
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbols   WatchlistItem[]
}

model WatchlistItem {
  id          String    @id @default(cuid())
  watchlistId String
  symbol      String
  assetClass  AssetClass
  exchange    String?
  sortOrder   Int       @default(0)
  addedAt     DateTime  @default(now())
  watchlist   Watchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)

  @@unique([watchlistId, symbol])
  @@index([symbol])
}

enum AssetClass {
  STOCK
  CRYPTO
  FOREX
  COMMODITY
  INDEX
}

// ─── ALERTS ──────────────────────────────────────────────────────

model Alert {
  id          String      @id @default(cuid())
  userId      String
  symbol      String
  name        String
  type        AlertType
  condition   AlertCondition
  value       Float
  indicator   String?     // for indicator alerts
  timeframe   String?
  isActive    Boolean     @default(true)
  triggered   Boolean     @default(false)
  triggeredAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([symbol, isActive])
}

enum AlertType {
  PRICE
  INDICATOR
  VOLUME
  PERCENT_CHANGE
}

enum AlertCondition {
  CROSSES_ABOVE
  CROSSES_BELOW
  GREATER_THAN
  LESS_THAN
  EQUALS
}

// ─── LAYOUTS ─────────────────────────────────────────────────────

model Layout {
  id          String   @id @default(cuid())
  userId      String
  name        String
  config      Json     // stores panel positions, sizes, widgets
  isDefault   Boolean  @default(false)
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── DRAWINGS ────────────────────────────────────────────────────

model Drawing {
  id          String      @id @default(cuid())
  userId      String
  symbol      String
  timeframe   String
  type        DrawingType
  data        Json        // coordinates, style, text, etc.
  version     Int         @default(1)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, symbol, timeframe])
}

enum DrawingType {
  TREND_LINE
  HORIZONTAL_LINE
  FIBONACCI
  RECTANGLE
  POSITION_TOOL
  TEXT
  BRUSH
}

// ─── SAVED INDICATORS ────────────────────────────────────────────

model SavedIndicator {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String   // SMA, EMA, RSI, custom...
  config    Json     // period, colors, parameters
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

enum NotificationType {
  ALERT_TRIGGERED
  SYSTEM
  PRICE_MOVEMENT
  NEWS
}

// ─── MARKET CACHE METADATA ───────────────────────────────────────

model MarketSymbol {
  id          String     @id @default(cuid())
  symbol      String     @unique
  name        String
  assetClass  AssetClass
  exchange    String
  currency    String
  logoUrl     String?
  isActive    Boolean    @default(true)
  metadata    Json?
  updatedAt   DateTime   @updatedAt

  @@index([assetClass])
  @@index([exchange])
}

// ─── SETTINGS & API KEYS ─────────────────────────────────────────

model UserSettings {
  id                String  @id @default(cuid())
  userId            String  @unique
  defaultSymbol     String  @default("BTC/USDT")
  defaultTimeframe  String  @default("60")
  emailAlerts       Boolean @default(false)
  browserAlerts     Boolean @default(true)
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  key       String   @unique
  label     String
  createdAt DateTime @default(now())
  lastUsed  DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── ALERT HISTORY ───────────────────────────────────────────────

model AlertHistory {
  id             String   @id @default(cuid())
  alertId        String
  userId         String
  symbol         String
  condition      String
  triggeredAt    DateTime @default(now())
  priceAtTrigger Float
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SOCIAL FEATURES ─────────────────────────────────

enum Sentiment {
  BULLISH
  BEARISH
  NEUTRAL
}

model Idea {
  id          String        @id @default(cuid())
  userId      String
  title       String
  body        String        @db.Text
  chartImage  String?
  symbol      String
  timeframe   String
  sentiment   Sentiment
  isPublic    Boolean       @default(true)
  viewCount   Int           @default(0)
  likeCount   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id])
  comments    IdeaComment[]
  likes       IdeaLike[]

  @@index([symbol])
  @@index([createdAt(sort: Desc)])
}

model IdeaComment {
  id        String   @id @default(cuid())
  ideaId    String
  userId    String
  body      String
  createdAt DateTime @default(now())
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model IdeaLike {
  userId    String
  ideaId    String
  createdAt DateTime @default(now())
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, ideaId])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("following", fields: [followerId], references: [id])
  following   User     @relation("followers", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

// ─── PAPER TRADING ───────────────────────────────────

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
  STOP_LOSS
  TRAILING_STOP
}

enum OrderStatus {
  PENDING
  FILLED
  CANCELLED
  REJECTED
}

model PaperAccount {
  id        String          @id @default(cuid())
  userId    String          @unique
  balance   Decimal         @default(100000.00) @db.Decimal(18, 2)
  currency  String          @default("USD")
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id])
  orders    PaperOrder[]
  positions PaperPosition[]
}

model PaperOrder {
  id          String       @id @default(cuid())
  accountId   String
  symbol      String
  side        OrderSide
  type        OrderType
  quantity    Decimal      @db.Decimal(18, 8)
  price       Decimal?     @db.Decimal(18, 8)
  status      OrderStatus
  filledAt    DateTime?
  filledPrice Decimal?     @db.Decimal(18, 8)
  createdAt   DateTime     @default(now())
  account     PaperAccount @relation(fields: [accountId], references: [id])
}

model PaperPosition {
  id            String       @id @default(cuid())
  accountId     String
  symbol        String
  quantity      Decimal      @db.Decimal(18, 8)
  avgEntryPrice Decimal      @db.Decimal(18, 8)
  side          OrderSide
  openedAt      DateTime     @default(now())
  closedAt      DateTime?
  realizedPnl   Decimal?     @db.Decimal(18, 8)
  account       PaperAccount @relation(fields: [accountId], references: [id])

  @@index([accountId, symbol])
}

// ─── SCREENER ────────────────────────────────────────

model SavedScreener {
  id        String   @id @default(cuid())
  userId    String
  name      String
  config    Json
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

// ─── SCRIPTING ENGINE ────────────────────────────────

enum ScriptType {
  INDICATOR
  STRATEGY
  LIBRARY
}

model Script {
  id          String     @id @default(cuid())
  userId      String
  name        String
  description String?
  code        String     @db.Text
  version     Int        @default(1)
  isPublic    Boolean    @default(false)
  likeCount   Int        @default(0)
  type        ScriptType
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id])
}
